# VidRush render worker — set these as Fly secrets (fly secrets set KEY=value)

# Shared bearer token; set the SAME value as RENDER_WORKER_TOKEN in the Vercel app.
RENDER_WORKER_TOKEN=

# AI33 (api.ai33.pro) — voiceover, voice cloning, and Suno music.
AI33_API_KEY=
# Optional default narration voice (provider-prefixed).
AI33_VOICE_ID=elevenlabs_21m00Tcm4TlvDq8ikWAM
# AI33_BASE_URL=https://api.ai33.pro

# Object storage for finished MP4s + mirrored audio (Cloudflare R2 / AWS S3 / Supabase S3).
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# R2: set the account id (endpoint auto-derived) OR set S3_ENDPOINT explicitly.
R2_ACCOUNT_ID=
# S3_ENDPOINT=
# S3_REGION=auto
# Public base URL for uploaded objects (R2 public bucket / CDN domain).
S3_PUBLIC_BASE_URL=

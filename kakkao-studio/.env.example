# Kakkao Studio — server-side API keys.
# All provider keys live here (or in Vercel → Project → Settings → Environment Variables)
# and are injected by /api/proxy at request time. They NEVER reach the browser. Copy this
# file to `.env` for local dev; set the same names in Vercel for production.

# --- Core ---
ANTHROPIC_API_KEY=          # topics, briefs, scripts, storyboards, SEO
YOUTUBE_API_KEY=            # YouTube Data API v3 — competitor scan, outliers, niche finder
GEMINI_API_KEY=             # "Learn from a video" analysis + built-in Gemini TTS voices

# --- Voice / music / images (AI33 — api.ai33.pro) ---
AI33_API_KEY=               # ElevenLabs/MiniMax/Fish voices + cloning, Suno music,
                            #   image frames (gpt-image-2) and thumbnails (nano-banana-pro)
AI33_BASE_URL=https://api.ai33.pro
GROQ_API_KEY=               # Groq Whisper — exact word-timed subtitles

# --- Footage sources (optional; Wikimedia + Internet Archive need no key) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=
COVERR_API_KEY=
NARA_API_KEY=               # U.S. National Archives (catalog.archives.gov)

# --- YouTube publishing (optional, browser OAuth — NOT injected by the proxy) ---
GOOGLE_CLIENT_ID=           # OAuth 2.0 Web client id for "Publish to YouTube"

# --- Cloud sync (optional: accounts + cross-device via Convex + Clerk) ---
# Leave unset to run local-only (localStorage). See README "Accounts & cloud sync".
VITE_CONVEX_URL=            # from `npx convex dev` or the Convex dashboard
CONVEX_DEPLOY_KEY=          # Convex production deploy key (Vercel builds push convex/)
VITE_CLERK_PUBLISHABLE_KEY= # Clerk dashboard → API Keys → Publishable key
